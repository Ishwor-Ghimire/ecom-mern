# Server Configuration
PORT=5001
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# JWT
JWT_SECRET=generate_a_64_byte_hex_secret_with_node_crypto

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

# Email Configuration (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=YourApp <your_email@gmail.com>

# WhatsApp Business Number (no +, no spaces)
WHATSAPP_NUMBER=977980000000
